<script>
// ====== STATE ======
let trades = [];
let habits = [
  {id:1,name:'Hydratation (2L)',emoji:'💧',status:null},
  {id:2,name:'Méditation',emoji:'🧘',status:null},
  {id:3,name:'Lecture 30 min',emoji:'📖',status:null},
  {id:4,name:'Sommeil 8h',emoji:'😴',status:null},
];
// Sessions: template avec exercices
let sessions = [
  {id:1,name:'Push 1',exercises:[
    {name:'Développé couché',group:'Pecs'},
    {name:'Écarté poulie haute',group:'Pecs'},
    {name:'Développé militaire',group:'Épaules'},
    {name:'Élévations latérales',group:'Épaules'},
    {name:'Triceps corde',group:'Triceps'},
  ]},
  {id:2,name:'Pull 1',exercises:[
    {name:'Tractions',group:'Dos'},
    {name:'Rowing barre',group:'Dos'},
    {name:'Face pull',group:'Épaules arrière'},
    {name:'Curl barre',group:'Biceps'},
  ]},
  {id:3,name:'Legs',exercises:[
    {name:'Squat',group:'Quadriceps'},
    {name:'Leg press',group:'Quadriceps'},
    {name:'Fentes',group:'Fessiers'},
    {name:'Soulevé de terre roumain',group:'Ischio'},
  ]},
];
// weekPlan[dayIdx] = {sessionId, sets:{exIdx:[{kg,reps},...]} }
let weekPlan = {};
// sessionHistory[sessionId] = [{date, exercises:[{name,group,sets:[{kg,reps}]}]}]
let sessionHistory = {};
// swimSessions = [{id, date, distance, duration, style, note}]
let swimSessions = [];
let budgetCats = [];
// tasks = [{id, date, ue, content, done}]
let tasks = [];
// lsTasks = [{id, date, title, desc, done}] — lifestyle scheduled tasks
let lsTasks = [];
// bodyWeight = [{id, date, kg}]
let bodyWeight = [];
let weightChart = null, reportPnlChart = null, reportWeightChart = null;
let selectedDay=0, assigningDay=null, editingSessionId=null, exCnt=0;
let pnlChart=null, currentPage='home';

// ====== NAV ======
function goTab(name){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tabitem').forEach(t=>t.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  const ti=document.getElementById('tab-'+name);
  if(ti) ti.classList.add('active');
  currentPage=name;
  document.getElementById('fab').style.display=name==='settings'?'none':'flex';
  if(name==='finance'){setTimeout(()=>{renderPnlChart();updateTradingTint();},80);}
  if(name==='sport'){ renderMuscu(); renderSwimStats(); }
  if(name==='lifestyle') { renderHabits(); renderLsScheduled(); }
  if(name==='home') renderHome();
  if(name==='cours') renderTasks();
  if(name==='finance') renderBudget();
  if(name==='report') setTimeout(renderReport, 80);
  if(name==='sport') renderWeightChart();
}
function switchSub(page,sub,el){
  document.querySelectorAll('#page-'+page+' .subpage').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('#page-'+page+' .stab').forEach(t=>t.classList.remove('active'));
  document.getElementById(page+'-'+sub).classList.add('active');
  el.classList.add('active');
  if(page==='finance'&&sub==='trading') setTimeout(renderPnlChart,80);
  if(page==='finance'&&sub==='gestion') renderBudget();
  if(page==='sport'&&sub==='swim') renderSwimStats();
}

// ====== FAB ======
function openFAB(){
  if(currentPage==='finance'){
    const isTrade=document.getElementById('finance-trading').classList.contains('active');
    if(isTrade) openOv('ov-trade');
    else openOv('ov-budget');
  } else if(currentPage==='lifestyle') openOv('ov-habit');
  else if(currentPage==='sport'){
    const isSwim=document.getElementById('sport-swim').classList.contains('active');
    if(isSwim){ resetSwimForm(); openOv('ov-swim'); }
    else { editingSessionId=null; openNewSessionModal(); }
  } else if(currentPage==='cours'){ resetTaskForm(); openOv('ov-task'); }
  else toast('Fonctionnalité à venir !');
}
function openOv(id){document.getElementById(id).classList.add('open');}
function closeOv(id){document.getElementById(id).classList.remove('open');}

// ====== THEME ======
function toggleTheme(){
  const html=document.documentElement;
  const dark=html.getAttribute('data-theme')==='dark';
  html.setAttribute('data-theme',dark?'light':'dark');
  const tog=document.getElementById('theme-tog');
  tog.classList.toggle('on',!dark);
}

// ====== EMOJI ======
function setEmoji(key,val){
  const el=document.getElementById('emo-'+key);
  if(el) el.textContent=val||'?';
}

// ====== TRADE ======
function calcTrade(){
  const dev=document.getElementById('t-devise').value;
  const pe=parseFloat(document.getElementById('t-pe').value);
  const sl=parseFloat(document.getElementById('t-sl').value);
  const tp=parseFloat(document.getElementById('t-tp').value);
  if(!pe||!sl||!tp) return;
  const isJpy=dev.includes('JPY')||dev==='XAU/USD'||dev==='US30'||dev==='NAS100';
  const pip=isJpy?0.01:0.0001;
  const psl=Math.abs(Math.round((pe-sl)/pip));
  const ptp=Math.abs(Math.round((tp-pe)/pip));
  const rr=psl>0?(ptp/psl).toFixed(2):'—';
  document.getElementById('c-rr').textContent=rr==='—'?'—':'1:'+rr;
  document.getElementById('c-psl').textContent=psl+' pips';
  document.getElementById('c-ptp').textContent=ptp+' pips';
}
function saveTrade(){
  const dev=document.getElementById('t-devise').value;
  const dir=document.getElementById('t-dir').value;
  const date=document.getElementById('t-date').value;
  const time=document.getElementById('t-time').value;
  const pe=parseFloat(document.getElementById('t-pe').value);
  const sl=parseFloat(document.getElementById('t-sl').value);
  const tp=parseFloat(document.getElementById('t-tp').value);
  if(!pe||!sl||!tp){toast('Remplis PE, SL et TP');return;}
  const isJpy=dev.includes('JPY')||dev==='XAU/USD'||dev==='US30'||dev==='NAS100';
  const pip=isJpy?0.01:0.0001;
  const psl=Math.abs(Math.round((pe-sl)/pip));
  const ptp=Math.abs(Math.round((tp-pe)/pip));
  const rr=psl>0?parseFloat((ptp/psl).toFixed(2)):0;
  const result=document.getElementById('t-result').value;
  const pnl=parseFloat(document.getElementById('t-pnl').value)||0;
  const disc=parseInt(document.getElementById('t-disc').value);
  const note=document.getElementById('t-note').value;
  trades.unshift({id:Date.now(),dev,dir,date,time,pe,sl,tp,psl,ptp,rr,result,pnl,disc,note});
  closeOv('ov-trade'); resetTradeForm();
  renderTrades(); renderPnlChart(); updateTradingTint(); renderHome();
  saveAll();
  toast('Trade enregistré ✓');
}
function resetTradeForm(){
  ['t-pe','t-sl','t-tp','t-pnl','t-note'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('t-disc').value=7;
  document.getElementById('disc-num').textContent='7';
  document.getElementById('t-result').value='';
  document.getElementById('c-rr').textContent='—';
  document.getElementById('c-psl').textContent='—';
  document.getElementById('c-ptp').textContent='—';
  const now=new Date();
  document.getElementById('t-date').value=now.toISOString().split('T')[0];
  document.getElementById('t-time').value=now.toTimeString().slice(0,5);
}
function renderTrades(){
  const el=document.getElementById('trades-list');
  if(!trades.length){el.innerHTML='<div class="empty"><i class="ti ti-chart-candle"></i>Appuie sur + pour logger ton premier trade</div>';updateTradeStats();return;}
  el.innerHTML=trades.map(t=>`
    <div class="traderow">
      <div class="tradedir ${t.dir==='long'?'td-buy':'td-sell'}">
        <i class="ti ti-arrow-${t.dir==='long'?'up':'down'}-right" style="font-size:20px;"></i>
      </div>
      <div class="trinfo">
        <div class="trpair">${t.dev} · ${t.dir==='long'?'Long':'Short'}</div>
        <div class="trmeta">PE ${t.pe} · SL ${t.sl} · TP ${t.tp}</div>
        <div class="trmeta">RR 1:${t.rr} · Disc. ${t.disc}/10</div>
      </div>
      <div class="trright">
        <div class="trpips ${t.result==='win'?'pos':t.result==='loss'?'neg':''}">${t.result==='win'?'+'+t.ptp+'p':t.result==='loss'?'-'+t.psl+'p':'~'+t.ptp+'p'}</div>
        <div style="font-size:11px;color:var(--muted);">${t.result==='win'?'Win ✓':t.result==='loss'?'Loss ✗':'En cours'}</div>
        ${t.pnl?`<div class="trpips ${t.pnl>=0?'pos':'neg'}" style="font-size:13px;">${t.pnl>=0?'+':''}${t.pnl}$</div>`:''}
      </div>
    </div>`).join('');
  updateTradeStats();
}
function updateTradeStats(){
  const done=trades.filter(t=>t.result);
  const wins=trades.filter(t=>t.result==='win').length;
  const losses=trades.filter(t=>t.result==='loss').length;
  const total=trades.reduce((a,t)=>a+t.pnl,0);
  const wr=done.length?Math.round(wins/done.length*100)+'%':'—';
  const avgRR=done.length?'1:'+(done.reduce((a,t)=>a+t.rr,0)/done.length).toFixed(2):'—';
  const avgD=trades.length?(trades.reduce((a,t)=>a+t.disc,0)/trades.length).toFixed(1)+'/10':'—';
  document.getElementById('pnl-big').textContent=(total>=0?'+':'')+total.toFixed(0)+' $';
  document.getElementById('pnl-big').className='pnlbig '+(total>=0?'pos':'neg');
  document.getElementById('st-wins').textContent=wins;
  document.getElementById('st-losses').textContent=losses;
  document.getElementById('st-wr').textContent=wr;
  document.getElementById('st-rr').textContent=avgRR;
  document.getElementById('st-disc').textContent=avgD;
  // Home
  const hpnl=document.getElementById('hc-pnl');
  hpnl.textContent=(total>=0?'+':'')+total.toFixed(0)+' $';
  hpnl.className='hcval '+(total>=0?'pos':'neg');
}
function updateTradingTint(){
  const pf=document.getElementById('page-finance');
  const total=trades.reduce((a,t)=>a+t.pnl,0);
  pf.className='page active '+(total>=0?'tint-trade-pos':'tint-trade-neg');
}
function renderPnlChart(){
  const canvas=document.getElementById('pnlChart'); if(!canvas) return;
  const sorted=[...trades].filter(t=>t.result).sort((a,b)=>new Date(a.date+' '+a.time)-new Date(b.date+' '+b.time));
  let cum=0, data=[0];
  sorted.forEach(t=>{cum+=t.pnl; data.push(parseFloat(cum.toFixed(2)));});
  const isPos=cum>=0, color=isPos?'#2eb872':'#e05252';
  if(pnlChart){pnlChart.destroy();pnlChart=null;}
  pnlChart=new Chart(canvas,{
    type:'line',
    data:{labels:data.map((_,i)=>i),datasets:[{data,borderColor:color,backgroundColor:isPos?'rgba(46,184,114,.07)':'rgba(224,82,82,.07)',fill:true,tension:.45,pointRadius:data.length>6?2:4,borderWidth:2.5}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},
      scales:{x:{display:false},y:{grid:{color:'rgba(128,128,128,0.07)'},ticks:{font:{size:10},color:color,callback:v=>(v>=0?'+':'')+v+'$'}}}}
  });
}

// ====== SWIM ======
function calcLaps(){
  const d=parseInt(document.getElementById('sw-dist-in').value)||0;
  const laps=Math.round(d/50);
  document.getElementById('sw-laps-calc').textContent=laps||'—';
  document.getElementById('sw-dist-calc').textContent=d?d+' m':'—';
}
function resetSwimForm(){
  document.getElementById('sw-dist-in').value='';
  document.getElementById('sw-dur').value='';
  document.getElementById('sw-note').value='';
  document.getElementById('sw-laps-calc').textContent='—';
  document.getElementById('sw-dist-calc').textContent='—';
  document.getElementById('sw-date').value=new Date().toISOString().split('T')[0];
}
function saveSwimSession(){
  const dist=parseInt(document.getElementById('sw-dist-in').value)||0;
  if(!dist){toast('Saisis la distance');return;}
  const date=document.getElementById('sw-date').value;
  const dur=document.getElementById('sw-dur').value.trim()||'—';
  const style=document.getElementById('sw-style').value;
  const note=document.getElementById('sw-note').value.trim();
  swimSessions.unshift({id:Date.now(),date,distance:dist,duration:dur,style,note});
  closeOv('ov-swim');
  renderSwimStats(); saveAll();
  toast('Séance natation enregistrée ✓');
}
function delSwimSession(id){
  swimSessions=swimSessions.filter(s=>s.id!==id);
  renderSwimStats(); saveAll();
}
function renderSwimStats(){
  // Filter current month
  const now=new Date();
  const thisMonth=swimSessions.filter(s=>{
    const d=new Date(s.date);
    return d.getFullYear()===now.getFullYear()&&d.getMonth()===now.getMonth();
  });
  const tot=thisMonth.reduce((a,s)=>a+s.distance,0);
  document.getElementById('sw-dist').innerHTML=(tot?tot.toLocaleString():'0')+'<span class="sunit"> m</span>';
  document.getElementById('sw-sess').textContent=thisMonth.length;
  document.getElementById('sw-avg').innerHTML=(thisMonth.length?Math.round(tot/thisMonth.length).toLocaleString():'0')+'<span class="sunit"> m</span>';
  const sl=document.getElementById('swim-sessions-list');
  if(!swimSessions.length){
    sl.innerHTML='<div class="empty"><i class="ti ti-swimming"></i>Appuie sur + pour ajouter une séance</div>';
    return;
  }
  sl.innerHTML=swimSessions.map(s=>{
    const laps=Math.round(s.distance/50);
    return `<div class="card" style="padding:14px;margin-bottom:10px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
        <span style="font-weight:800;">${formatDate(s.date)}</span>
        <div style="display:flex;align-items:center;gap:10px;">
          <span style="color:var(--muted);font-size:13px;">${s.duration}</span>
          <button onclick="delSwimSession(${s.id})" style="background:transparent;border:none;color:var(--muted);cursor:pointer;font-size:16px;padding:2px;"><i class="ti ti-trash"></i></button>
        </div>
      </div>
      <div style="display:flex;gap:16px;flex-wrap:wrap;">
        <div style="font-size:12px;color:var(--muted);">Distance<br><span style="font-weight:800;color:#38bdf8;font-size:16px;">${s.distance.toLocaleString()} m</span></div>
        <div style="font-size:12px;color:var(--muted);">Laps<br><span style="font-weight:800;color:var(--text);font-size:16px;">${laps}</span></div>
        <div style="font-size:12px;color:var(--muted);">Style<br><span style="font-weight:800;color:var(--text);font-size:16px;">${s.style}</span></div>
        ${s.note?`<div style="font-size:12px;color:var(--muted);flex:1;">Note<br><span style="color:var(--text);font-size:13px;">${s.note}</span></div>`:''}
      </div>
    </div>`;
  }).join('');
}
function formatDate(d){
  const days=['Dim.','Lun.','Mar.','Mer.','Jeu.','Ven.','Sam.'];
  const months=['jan','fév','mars','avr','mai','juin','juil','août','sep','oct','nov','déc'];
  const dt=new Date(d); return days[dt.getDay()]+' '+dt.getDate()+' '+months[dt.getMonth()];
}

// ====== MUSCU ======
function renderMuscu(){ renderWeekGrid(); renderDayContent(); renderSessionsList(); }
function getSession(id){ return sessions.find(s=>s.id===id); }
function renderWeekGrid(){
  document.getElementById('week-grid').innerHTML=DAYS.map((d,i)=>{
    const p=weekPlan[i], active=selectedDay===i;
    const sname=p?getSession(p.sessionId)?.name||'?':'—';
    return `<div class="wday ${active?'active':''} ${p&&!active?'has':''}" onclick="selectDay(${i})">
      <div class="wdname">${d}</div>
      <div class="wdsess">${sname}</div>
      ${p&&!active?'<div class="wdot"></div>':''}
    </div>`;
  }).join('');
}
function selectDay(i){
  selectedDay=i;
  if(weekPlan[i]){renderWeekGrid();renderDayContent();}
  else{assigningDay=i;openAssignModal();}
}
function openAssignModal(){
  document.getElementById('assign-title').textContent='Séance — '+DAYS[assigningDay];
  document.getElementById('assign-list').innerHTML=sessions.length
    ?sessions.map(s=>`<button class="btn btng" style="margin-bottom:8px;text-align:left;" onclick="assignDay(${s.id})">${s.name} · ${s.exercises.length} exos</button>`).join('')
    :'<p style="color:var(--muted);font-size:13px;margin-bottom:12px;">Crée d\'abord une séance type (bouton +).</p>';
  openOv('ov-assign');
}
function assignDay(sessionId){
  if(sessionId===null){weekPlan[assigningDay]=null;}
  else{
    const s=getSession(sessionId); if(!s) return;
    // Keep existing sets if same session, else fresh init
    const existing=weekPlan[assigningDay];
    if(!existing||existing.sessionId!==sessionId){
      const sets={};
      s.exercises.forEach((_,i)=>{sets[i]=[{kg:'',reps:''}];});
      weekPlan[assigningDay]={sessionId,sets};
    }
  }
  closeOv('ov-assign'); renderMuscu(); updateTodayMuscu(); saveAll();
}
function updateTodayMuscu(){
  const todayIdx=(new Date().getDay()+6)%7;
  const p=weekPlan[todayIdx];
  document.getElementById('hc-muscu').textContent=p?getSession(p.sessionId)?.name||'—':'—';
}
function renderDayContent(){
  const cont=document.getElementById('day-content');
  const plan=weekPlan[selectedDay];
  if(!plan){cont.innerHTML=`<div class="empty" style="padding:20px 0;"><i class="ti ti-moon"></i>Repos — clique pour assigner</div>`;return;}
  const sess=getSession(plan.sessionId); if(!sess){cont.innerHTML='';return;}
  cont.innerHTML=`
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
      <div style="font-size:16px;font-weight:800;">${DAYS[selectedDay]} — ${sess.name}</div>
      <button onclick="clearDay()" style="background:transparent;border:none;color:var(--muted);cursor:pointer;font-size:13px;">Effacer</button>
    </div>
    ${sess.exercises.map((ex,ei)=>{
      const sets=plan.sets[ei]||[{kg:'',reps:''}];
      return `<div class="exblock">
        <div class="exhead"><span class="exname">${ex.name}</span><span class="exgrp">${ex.group}</span></div>
        <div class="setscol" id="sc-${ei}">${sets.map((s,si)=>setRowHTML(ei,si,s)).join('')}</div>
        <button class="addsetbtn" onclick="addSet(${ei})"><i class="ti ti-plus"></i> Série</button>
      </div>`;
    }).join('')}
    <button class="btn btnp" style="margin-top:8px;" onclick="saveWorkout()">💾 Enregistrer la séance</button>`;
}
function setRowHTML(ei,si,s){
  return `<div class="setrow" id="sr-${ei}-${si}">
    <div class="setbadge">${si+1}</div>
    <input class="setin" type="number" placeholder="kg" value="${s.kg||''}" onchange="updateSet(${ei},${si},'kg',this.value)">
    <input class="setin" type="number" placeholder="reps" value="${s.reps||''}" onchange="updateSet(${ei},${si},'reps',this.value)">
    <button class="setdel" onclick="removeSet(${ei},${si})"><i class="ti ti-x" style="font-size:14px;color:var(--muted);"></i></button>
  </div>`;
}
function updateSet(ei,si,field,val){
  const p=weekPlan[selectedDay]; if(!p||!p.sets[ei]) return;
  p.sets[ei][si][field]=val;
  saveAll();
}
function addSet(ei){
  const p=weekPlan[selectedDay]; if(!p) return;
  if(!p.sets[ei]) p.sets[ei]=[];
  p.sets[ei].push({kg:'',reps:''});
  renderDayContent();
}
function removeSet(ei,si){
  const p=weekPlan[selectedDay]; if(!p||!p.sets[ei]) return;
  if(p.sets[ei].length>1){p.sets[ei].splice(si,1);renderDayContent();}
}
function clearDay(){weekPlan[selectedDay]=null;renderMuscu();saveAll();}
function saveWorkout(){
  const p=weekPlan[selectedDay]; if(!p) return;
  const sess=getSession(p.sessionId); if(!sess) return;
  // Deep copy sets as record, keyed to sessionId
  const record={
    date:new Date().toISOString().split('T')[0],
    day:DAYS[selectedDay],
    exercises:sess.exercises.map((ex,ei)=>({
      name:ex.name,group:ex.group,
      sets:(p.sets[ei]||[]).map(s=>({kg:parseFloat(s.kg)||0,reps:parseInt(s.reps)||0})).filter(s=>s.kg||s.reps)
    }))
  };
  if(!sessionHistory[p.sessionId]) sessionHistory[p.sessionId]=[];
  sessionHistory[p.sessionId].unshift(record);
  renderMuscuHomeProgress();
  saveAll();
  toast('Séance enregistrée ✓');
}
function renderSessionsList(){
  const el=document.getElementById('sessions-list');
  if(!sessions.length){el.innerHTML='<div class="empty">Appuie sur + pour créer une séance</div>';return;}
  el.innerHTML=sessions.map(s=>`
    <div class="sesscard">
      <div class="sesshead" onclick="editSession(${s.id})">
        <span class="sessname">${s.name}</span>
        <div style="display:flex;align-items:center;gap:8px;">
          <span class="sesscount">${s.exercises.length} exos</span>
          <button onclick="event.stopPropagation();delSession(${s.id})" style="background:transparent;border:none;color:var(--muted);cursor:pointer;font-size:16px;padding:2px;"><i class="ti ti-trash"></i></button>
        </div>
      </div>
      <div class="exchips" onclick="editSession(${s.id})">${s.exercises.map(e=>`<span class="exchip">${e.name}</span>`).join('')}</div>
    </div>`).join('');
}
function delSession(id){
  sessions=sessions.filter(s=>s.id!==id);
  // Remove from weekPlan too
  Object.keys(weekPlan).forEach(day=>{if(weekPlan[day]&&weekPlan[day].sessionId===id) weekPlan[day]=null;});
  renderMuscu(); saveAll();
  toast('Séance supprimée');
}
function openNewSessionModal(){
  document.getElementById('msess-title').textContent='Nouvelle séance type';
  document.getElementById('ms-name').value='';
  document.getElementById('ms-exlist').innerHTML='';
  exCnt=0; addExModal(); addExModal(); addExModal();
  openOv('ov-session');
}
function editSession(id){
  const s=sessions.find(s=>s.id===id); if(!s) return;
  editingSessionId=id;
  document.getElementById('msess-title').textContent='Modifier : '+s.name;
  document.getElementById('ms-name').value=s.name;
  document.getElementById('ms-exlist').innerHTML='';
  exCnt=0;
  s.exercises.forEach(ex=>addExModal(ex.name,ex.group));
  openOv('ov-session');
}
function addExModal(name='',group=''){
  exCnt++;
  const div=document.createElement('div');
  div.className='frow'; div.style.marginBottom='8px';
  div.innerHTML=`<input type="text" placeholder="Exercice" value="${name}"><input type="text" placeholder="Groupe musculaire" value="${group}">`;
  document.getElementById('ms-exlist').appendChild(div);
}
function saveSession(){
  const name=document.getElementById('ms-name').value.trim();
  if(!name){toast('Nomme la séance');return;}
  const rows=document.getElementById('ms-exlist').querySelectorAll('.frow');
  const exs=[];
  rows.forEach(r=>{
    const ins=r.querySelectorAll('input');
    const n=ins[0].value.trim(),g=ins[1].value.trim();
    if(n) exs.push({name:n,group:g||'Général'});
  });
  if(!exs.length){toast('Ajoute au moins un exercice');return;}
  if(editingSessionId){
    const idx=sessions.findIndex(s=>s.id===editingSessionId);
    if(idx>=0){
      sessions[idx]={...sessions[idx],name,exercises:exs};
      // Repair weekPlan sets if session modified
      Object.keys(weekPlan).forEach(day=>{
        const p=weekPlan[day];
        if(p&&p.sessionId===editingSessionId){
          const ns={};
          exs.forEach((_,i)=>{ns[i]=p.sets[i]||[{kg:'',reps:''}];});
          weekPlan[day].sets=ns;
        }
      });
    }
    editingSessionId=null;
  } else {
    sessions.push({id:Date.now(),name,exercises:exs});
  }
  closeOv('ov-session'); renderMuscu();
  saveAll();
  toast('Séance sauvegardée ✓');
}

// ====== MUSCU HOME PROGRESS ======
function renderMuscuHomeProgress(){
  const el=document.getElementById('home-muscu-prog');
  const allRec=Object.values(sessionHistory).flat();
  if(!allRec.length){el.innerHTML='<div class="empty"><i class="ti ti-barbell"></i>Lance ta première séance pour voir ta progression</div>';return;}
  // Group by exercise, track avg kg over sessions
  const exMap={};
  [...allRec].sort((a,b)=>new Date(a.date)-new Date(b.date)).forEach(rec=>{
    rec.exercises.forEach(ex=>{
      const maxKg=ex.sets.length?Math.max(...ex.sets.map(s=>s.kg||0)):0;
      if(maxKg>0){
        if(!exMap[ex.name]) exMap[ex.name]=[];
        exMap[ex.name].push(maxKg);
      }
    });
  });
  const names=Object.keys(exMap).slice(0,4);
  if(!names.length){el.innerHTML='<div class="empty"><i class="ti ti-barbell"></i>Remplis tes séances pour voir la progression</div>';return;}
  el.innerHTML='<div style="padding:4px 0;">'+names.map(n=>{
    const pts=exMap[n], first=pts[0], last=pts[pts.length-1], diff=+(last-first).toFixed(1);
    const pct=first>0?Math.min(100,Math.round(last/first*100)):100;
    return `<div class="mhprow">
      <div class="mhpname">${n}</div>
      <div class="mhpbar"><div class="mhpfill" style="width:${pct}%;background:${diff>=0?'var(--green)':'var(--red)'}"></div></div>
      <div class="mhpdiff" style="color:${diff>=0?'var(--green)':'var(--red)'};">${diff>=0?'+':''}${diff} kg</div>
    </div>`;
  }).join('')+'</div>';
}

// ====== HABITS ======
function renderHabits(){
  const el=document.getElementById('habits-list');
  if(!habits.length){el.innerHTML='<div class="empty">Appuie sur + pour ajouter une habitude</div>';updateLsScore();return;}
  el.innerHTML=habits.map(h=>`
    <div class="hrow">
      <div class="hemi">${h.emoji||'⭕'}</div>
      <div class="hname">${h.name}</div>
      <div style="display:flex;gap:8px;">
        <button class="hbtn ${h.status===true?'y':''}" onclick="setHabit(${h.id},true)"><i class="ti ti-check" style="font-size:15px;"></i></button>
        <button class="hbtn ${h.status===false?'n':''}" onclick="setHabit(${h.id},false)"><i class="ti ti-x" style="font-size:15px;"></i></button>
      </div>
      <button class="hdel" onclick="delHabit(${h.id})"><i class="ti ti-trash" style="font-size:14px;"></i></button>
    </div>`).join('');
  updateLsScore();
}
function setHabit(id,val){
  const h=habits.find(h=>h.id===id); if(!h) return;
  h.status=h.status===val?null:val;
  renderHabits(); renderHome(); saveAll();
}
function delHabit(id){habits=habits.filter(h=>h.id!==id);renderHabits();renderHome();saveAll();}
function saveHabit(){
  const name=document.getElementById('h-name').value.trim();
  if(!name){toast('Saisis un nom');return;}
  const emoji=document.getElementById('h-emoji').value||'⭕';
  habits.push({id:Date.now(),name,emoji,status:null});
  document.getElementById('h-name').value='';document.getElementById('h-emoji').value='';
  closeOv('ov-habit'); renderHabits(); renderHome();
  saveAll();
  toast('Habitude ajoutée ✓');
}
function updateLsScore(){
  const done=habits.filter(h=>h.status===true).length, tot=habits.length;
  document.getElementById('ls-done').textContent=done;
  document.getElementById('ls-total').textContent=tot;
  document.getElementById('ls-bar').style.width=(tot?Math.round(done/tot*100):0)+'%';
}

// ====== BUDGET ======
function renderBudget(){
  const el=document.getElementById('budget-wrap');
  const totalSpent=budgetCats.reduce((a,c)=>a+c.spent,0);
  const totalMax=budgetCats.reduce((a,c)=>a+c.max,0);
  // Update gestion header
  const now=new Date();
  const months=['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];
  const gm=document.getElementById('gest-month');
  if(gm) gm.textContent=months[now.getMonth()]+' '+now.getFullYear();
  const gs=document.getElementById('gest-solde');
  if(gs) gs.textContent=(totalMax-totalSpent).toLocaleString()+' €';
  const gi=document.getElementById('gest-in');
  if(gi) gi.textContent='+'+totalMax.toLocaleString()+' €';
  const go=document.getElementById('gest-out');
  if(go) go.textContent='-'+totalSpent.toLocaleString()+' €';
  if(!budgetCats.length){
    el.innerHTML=`<div class="empty" style="padding:16px 0;"><i class="ti ti-wallet"></i>Aucune catégorie</div><button class="btn btng" style="margin-top:6px;" onclick="openOv('ov-budget')"><i class="ti ti-plus"></i> Ajouter une catégorie</button>`;
    return;
  }
  el.innerHTML=budgetCats.map(c=>{
    const pct=c.max>0?Math.min(100,Math.round(c.spent/c.max*100)):0;
    const cls=pct>=100?'bover':pct>=80?'bwarn':'bok';
    return `<div class="bcat">
      <div class="bcath">
        <span class="bcatn">${c.name}</span>
        <div style="display:flex;align-items:center;gap:6px;">
          <span class="bcatamt">${c.spent.toLocaleString()} / ${c.max.toLocaleString()} €</span>
          <button class="bcatdel" onclick="delBudget(${c.id})"><i class="ti ti-trash" style="font-size:13px;"></i></button>
        </div>
      </div>
      <div class="bbarw"><div class="bbar ${cls}" style="width:${pct}%;"></div></div>
    </div>`;
  }).join('')+`<button class="btn btng" style="margin-top:6px;" onclick="openOv('ov-budget')"><i class="ti ti-plus"></i> Ajouter une catégorie</button>`;
}
function delBudget(id){budgetCats=budgetCats.filter(c=>c.id!==id);renderBudget();saveAll();}
function saveBudget(){
  const name=document.getElementById('bc-name').value.trim();
  if(!name){toast('Nomme la catégorie');return;}
  const spent=parseFloat(document.getElementById('bc-spent').value)||0;
  const max=parseFloat(document.getElementById('bc-max').value)||0;
  budgetCats.push({id:Date.now(),name,spent,max});
  ['bc-name','bc-spent','bc-max'].forEach(id=>document.getElementById(id).value='');
  closeOv('ov-budget'); renderBudget(); saveAll();
  toast('Catégorie ajoutée ✓');
}

// ====== TASKS / COURS ======
function resetTaskForm(){
  document.getElementById('tk-date').value=new Date().toISOString().split('T')[0];
  document.getElementById('tk-ue').value='';
  document.getElementById('tk-content').value='';
}
function saveTask(){
  const date=document.getElementById('tk-date').value;
  const ue=document.getElementById('tk-ue').value.trim();
  const content=document.getElementById('tk-content').value.trim();
  if(!ue){toast('Saisis la matière');return;}
  tasks.push({id:Date.now(),date,ue,content,done:false});
  tasks.sort((a,b)=>new Date(a.date)-new Date(b.date));
  closeOv('ov-task'); renderTasks(); updateCours(); saveAll();
  toast('Tâche ajoutée ✓');
}
function toggleTask(id){
  const t=tasks.find(t=>t.id===id);
  if(t){t.done=!t.done;renderTasks();updateCours();saveAll();}
}
function delTask(id){
  tasks=tasks.filter(t=>t.id!==id);
  renderTasks(); updateCours(); saveAll();
}
function renderTasks(){
  const container=document.getElementById('tasks-container');
  if(!tasks.length){
    container.innerHTML='<div class="empty" style="padding:40px 20px;"><i class="ti ti-calendar"></i>Aucune tâche — appuie sur + pour en ajouter</div>';
    return;
  }
  // Group by date
  const groups={};
  tasks.forEach(t=>{
    if(!groups[t.date]) groups[t.date]=[];
    groups[t.date].push(t);
  });
  const months=['jan','fév','mars','avr','mai','juin','juil','août','sep','oct','nov','déc'];
  const dayNames=['Dim.','Lun.','Mar.','Mer.','Jeu.','Ven.','Sam.'];
  container.innerHTML=Object.keys(groups).sort().map(date=>{
    const dt=new Date(date+'T12:00:00');
    const label=dayNames[dt.getDay()]+' '+dt.getDate()+' '+months[dt.getMonth()];
    const items=groups[date];
    const doneCount=items.filter(t=>t.done).length;
    return `<div class="card" style="margin-bottom:12px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
        <span style="font-size:15px;font-weight:800;">${label}</span>
        <span style="font-size:11px;color:var(--muted);background:var(--card2);padding:2px 8px;border-radius:8px;">${doneCount}/${items.length}</span>
      </div>
      ${items.map(t=>`
        <div class="taskrow">
          <div class="tchk ${t.done?'done':''}" onclick="toggleTask(${t.id})">${t.done?'<i class="ti ti-check" style="font-size:11px;color:#fff;"></i>':''}</div>
          <div style="flex:1;min-width:0;" onclick="toggleTask(${t.id})">
            <div class="ttxt ${t.done?'done':''}" style="font-weight:700;">${t.ue}</div>
            ${t.content?`<div style="font-size:12px;color:var(--muted);margin-top:2px;${t.done?'text-decoration:line-through;':''}">${t.content}</div>`:''}
          </div>
          <button onclick="delTask(${t.id})" style="background:transparent;border:none;color:var(--muted);cursor:pointer;font-size:16px;padding:4px;flex-shrink:0;"><i class="ti ti-trash"></i></button>
        </div>`).join('')}
    </div>`;
  }).join('');
}
function updateCours(){
  const rem=tasks.filter(t=>!t.done).length;
  document.getElementById('hc-cours').textContent=rem+' tâche'+(rem>1?'s':'');
}

// ====== HOME ======
function renderHome(){
  updateTodayMuscu(); updateTradeStats(); updateLsScore(); updateCours();
  // habits card
  const done=habits.filter(h=>h.status===true).length;
  document.getElementById('hc-habits').textContent=done+'/'+habits.length;
  // last 2 trades
  const ht=document.getElementById('home-trades');
  if(!trades.length){ht.innerHTML='<div class="empty" style="padding:16px 0;"><i class="ti ti-chart-candle"></i>Aucun trade</div>';return;}
  ht.innerHTML=trades.slice(0,2).map(t=>`
    <div class="traderow">
      <div class="tradedir ${t.dir==='long'?'td-buy':'td-sell'}">
        <i class="ti ti-arrow-${t.dir==='long'?'up':'down'}-right" style="font-size:18px;"></i>
      </div>
      <div class="trinfo">
        <div class="trpair">${t.dev} · ${t.dir==='long'?'Long':'Short'}</div>
        <div class="trmeta">${t.result==='win'?'Win ✓':t.result==='loss'?'Loss ✗':'En cours'} · Disc ${t.disc}/10</div>
      </div>
      <div class="trright">
        <div class="trpips ${t.pnl>=0?'pos':'neg'}">${t.pnl>=0?'+':''}${t.pnl}$</div>
      </div>
    </div>`).join('');
}

// ====== LIFESTYLE SCHEDULED TASKS ======
function saveLsTask(){
  const date=document.getElementById('lst-date').value;
  const title=document.getElementById('lst-title').value.trim();
  const desc=document.getElementById('lst-desc').value.trim();
  if(!title){toast('Saisis un titre');return;}
  lsTasks.push({id:Date.now(),date,title,desc,done:false});
  lsTasks.sort((a,b)=>new Date(a.date)-new Date(b.date));
  ['lst-date','lst-title','lst-desc'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('lst-date').value=new Date().toISOString().split('T')[0];
  closeOv('ov-ls-task');
  renderLsScheduled(); saveAll();
  toast('Tâche programmée ✓');
}
function toggleLsTask(id){
  const t=lsTasks.find(t=>t.id===id); if(!t) return;
  t.done=!t.done;
  renderLsScheduled(); saveAll();
}
function delLsTask(id){
  lsTasks=lsTasks.filter(t=>t.id!==id);
  renderLsScheduled(); saveAll();
}
function renderLsScheduled(){
  const today=new Date().toISOString().split('T')[0];
  const months=['jan','fév','mars','avr','mai','juin','juil','août','sep','oct','nov','déc'];
  const dayNames=['Dim.','Lun.','Mar.','Mer.','Jeu.','Ven.','Sam.'];

  // Tasks due today — shown at top
  const todayTasks=lsTasks.filter(t=>t.date===today);
  const todayEl=document.getElementById('ls-scheduled-today');
  if(todayTasks.length){
    todayEl.innerHTML=`<div class="card" style="margin-bottom:12px;border:.5px solid rgba(192,132,252,.4);">
      <div style="font-size:13px;font-weight:700;color:var(--purple);margin-bottom:10px;">📅 Tâches du jour</div>
      ${todayTasks.map(t=>`
        <div class="taskrow">
          <div class="tchk ${t.done?'done':''}" onclick="toggleLsTask(${t.id})">${t.done?'<i class="ti ti-check" style="font-size:11px;color:#fff;"></i>':''}</div>
          <div style="flex:1;" onclick="toggleLsTask(${t.id})">
            <div class="ttxt ${t.done?'done':''}" style="font-weight:700;">${t.title}</div>
            ${t.desc?`<div style="font-size:12px;color:var(--muted);">${t.desc}</div>`:''}
          </div>
          <button onclick="delLsTask(${t.id})" style="background:transparent;border:none;color:var(--muted);cursor:pointer;font-size:16px;padding:4px;"><i class="ti ti-trash"></i></button>
        </div>`).join('')}
    </div>`;
  } else { todayEl.innerHTML=''; }

  // All scheduled tasks grouped by date
  const allEl=document.getElementById('ls-scheduled-all');
  const future=lsTasks.filter(t=>t.date>=today&&t.date!==today);
  const past=lsTasks.filter(t=>t.date<today);
  const all=[...future,...past];
  if(!all.length){ allEl.innerHTML='<div style="color:var(--muted);font-size:13px;padding:8px 0 16px;">Aucune tâche programmée</div>'; return; }
  const groups={};
  all.forEach(t=>{ if(!groups[t.date]) groups[t.date]=[]; groups[t.date].push(t); });
  allEl.innerHTML=Object.keys(groups).sort().map(date=>{
    const dt=new Date(date+'T12:00:00');
    const label=dayNames[dt.getDay()]+' '+dt.getDate()+' '+months[dt.getMonth()]+' '+dt.getFullYear();
    const isPast=date<today;
    return `<div class="card" style="margin-bottom:8px;${isPast?'opacity:.6;':''}">
      <div style="font-size:12px;font-weight:700;color:${isPast?'var(--red)':'var(--muted)'};margin-bottom:8px;">${label}${isPast?' · Passé':''}</div>
      ${groups[date].map(t=>`
        <div class="taskrow">
          <div class="tchk ${t.done?'done':''}" onclick="toggleLsTask(${t.id})">${t.done?'<i class="ti ti-check" style="font-size:11px;color:#fff;"></i>':''}</div>
          <div style="flex:1;" onclick="toggleLsTask(${t.id})">
            <div class="ttxt ${t.done?'done':''}" style="font-weight:700;">${t.title}</div>
            ${t.desc?`<div style="font-size:12px;color:var(--muted);">${t.desc}</div>`:''}
          </div>
          <button onclick="delLsTask(${t.id})" style="background:transparent;border:none;color:var(--muted);cursor:pointer;font-size:16px;padding:4px;"><i class="ti ti-trash"></i></button>
        </div>`).join('')}
    </div>`;
  }).join('');
}

// ====== BODYWEIGHT ======
function openWeightModal(){
  document.getElementById('w-date').value=new Date().toISOString().split('T')[0];
  document.getElementById('w-kg').value='';
  openOv('ov-weight');
}
function saveWeight(){
  const date=document.getElementById('w-date').value;
  const kg=parseFloat(document.getElementById('w-kg').value);
  if(!kg){toast('Saisis ton poids');return;}
  // Replace if same date
  bodyWeight=bodyWeight.filter(w=>w.date!==date);
  bodyWeight.push({id:Date.now(),date,kg});
  bodyWeight.sort((a,b)=>new Date(a.date)-new Date(b.date));
  closeOv('ov-weight');
  renderWeightChart(); saveAll();
  toast('Poids enregistré ✓');
}
function renderWeightChart(){
  const el=document.getElementById('muscu-current-weight');
  const diffEl=document.getElementById('muscu-weight-diff');
  const canvas=document.getElementById('weightChart');
  if(!bodyWeight.length){
    if(el) el.textContent='— kg';
    if(diffEl){ diffEl.textContent='—'; diffEl.style.color='var(--muted)'; }
    return;
  }
  const last=bodyWeight[bodyWeight.length-1];
  const first=bodyWeight[0];
  const diff=+(last.kg-first.kg).toFixed(1);
  if(el) el.textContent=last.kg+' kg';
  if(diffEl){
    diffEl.textContent=(diff>=0?'+':'')+diff+' kg';
    diffEl.style.color=diff<=0?'var(--green)':'var(--red)';
  }
  if(!canvas) return;
  if(weightChart){weightChart.destroy();weightChart=null;}
  weightChart=new Chart(canvas,{
    type:'line',
    data:{
      labels:bodyWeight.map(w=>{const d=new Date(w.date+'T12:00:00');return d.getDate()+'/'+(d.getMonth()+1);}),
      datasets:[{
        data:bodyWeight.map(w=>w.kg),
        borderColor:'#aaa',backgroundColor:'rgba(170,170,170,.07)',
        fill:true,tension:.4,pointRadius:4,borderWidth:2.5,
        pointBackgroundColor:'#aaa'
      }]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false}},
      scales:{
        x:{ticks:{font:{size:9},color:'#666'},grid:{display:false}},
        y:{ticks:{font:{size:9},color:'#666',callback:v=>v+'kg'},grid:{color:'rgba(128,128,128,.07)'}}
      }
    }
  });
}

// ====== REPORT ======
function renderReport(){
  const el=document.getElementById('report-content');
  const months=['jan','fév','mars','avr','mai','juin','juil','août','sep','oct','nov','déc'];

  // ── FINANCE ──
  const totalPnl=trades.reduce((a,t)=>a+t.pnl,0);
  const done=trades.filter(t=>t.result);
  const wins=done.filter(t=>t.result==='win').length;
  const wr=done.length?Math.round(wins/done.length*100):0;
  const avgRR=done.length?(done.reduce((a,t)=>a+t.rr,0)/done.length).toFixed(2):'—';
  const avgDisc=trades.length?(trades.reduce((a,t)=>a+t.disc,0)/trades.length).toFixed(1):'—';

  // ── SPORT: SWIM ──
  const now=new Date();
  const thisMonth=swimSessions.filter(s=>{const d=new Date(s.date);return d.getFullYear()===now.getFullYear()&&d.getMonth()===now.getMonth();});
  const swimDist=thisMonth.reduce((a,s)=>a+s.distance,0);

  // ── SPORT: MUSCU ──
  const allRec=Object.values(sessionHistory).flat();
  const exMap={};
  [...allRec].sort((a,b)=>new Date(a.date)-new Date(b.date)).forEach(rec=>{
    rec.exercises.forEach(ex=>{
      const maxKg=ex.sets.length?Math.max(...ex.sets.map(s=>s.kg||0)):0;
      if(maxKg>0){if(!exMap[ex.name])exMap[ex.name]=[];exMap[ex.name].push(maxKg);}
    });
  });
  const exNames=Object.keys(exMap);
  let totalProgKg=0; let progCount=0;
  exNames.forEach(n=>{const pts=exMap[n];if(pts.length>1){totalProgKg+=(pts[pts.length-1]-pts[0]);progCount++;}});
  const avgProg=progCount>0?(totalProgKg/progCount).toFixed(1):'—';

  // ── LIFESTYLE ──
  const habDone=habits.filter(h=>h.status===true).length;
  const habTotal=habits.length;
  const lsScore=habTotal>0?Math.round(habDone/habTotal*100):0;
  const lsDone=lsTasks.filter(t=>t.done).length;
  const lsAll=lsTasks.length;

  el.innerHTML=`
    <!-- FINANCE -->
    <div class="seclbl">📊 Finance — Trading</div>
    <div class="card" style="margin-bottom:12px;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;">
        <div class="scard"><div class="slbl">PNL total</div><div class="sval ${totalPnl>=0?'pos':'neg'}">${totalPnl>=0?'+':''}${totalPnl.toFixed(0)}<span class="sunit"> $</span></div></div>
        <div class="scard"><div class="slbl">Win rate</div><div class="sval">${wr}<span class="sunit">%</span></div></div>
        <div class="scard"><div class="slbl">RR moyen</div><div class="sval">1:<span>${avgRR}</span></div></div>
        <div class="scard"><div class="slbl">Discipline moy.</div><div class="sval">${avgDisc}<span class="sunit">/10</span></div></div>
      </div>
      <div style="font-size:13px;font-weight:800;margin-bottom:8px;">Courbe PNL</div>
      <div style="height:120px;"><canvas id="report-pnl-chart"></canvas></div>
    </div>

    <!-- SPORT SWIM -->
    <div class="seclbl">🏊 Sport — Natation (ce mois)</div>
    <div class="card" style="margin-bottom:12px;">
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
        <div class="scard swim-card"><div class="slbl">Distance</div><div class="sval swim-c" style="font-size:18px;">${swimDist.toLocaleString()}<span class="sunit">m</span></div></div>
        <div class="scard swim-card"><div class="slbl">Séances</div><div class="sval swim-c" style="font-size:18px;">${thisMonth.length}</div></div>
        <div class="scard swim-card"><div class="slbl">Moy.</div><div class="sval swim-c" style="font-size:18px;">${thisMonth.length?Math.round(swimDist/thisMonth.length).toLocaleString():'0'}<span class="sunit">m</span></div></div>
      </div>
    </div>

    <!-- SPORT MUSCU -->
    <div class="seclbl">🏋️ Sport — Musculation</div>
    <div class="card" style="margin-bottom:12px;">
      ${exNames.length?`
        <div style="margin-bottom:12px;">${exNames.slice(0,5).map(n=>{
          const pts=exMap[n]; const diff=+(pts[pts.length-1]-pts[0]).toFixed(1);
          return `<div class="mhprow"><div class="mhpname">${n}</div>
            <div class="mhpbar"><div class="mhpfill" style="width:${Math.min(100,pts[pts.length-1]/Math.max(...pts)*100)}%;background:${diff>=0?'var(--green)':'var(--red)'}"></div></div>
            <div class="mhpdiff" style="color:${diff>=0?'var(--green)':'var(--red)'};">${diff>=0?'+':''}${diff}kg</div></div>`;
        }).join('')}</div>
        <div style="font-size:13px;color:var(--muted);">Progression moy. sur tous les exos : <span style="font-weight:800;color:${parseFloat(avgProg)>=0?'var(--green)':'var(--red)'};">${avgProg>=0?'+':''}${avgProg} kg</span></div>
      `:'<div class="empty" style="padding:12px 0;"><i class="ti ti-barbell"></i>Aucune donnée muscu</div>'}
      ${bodyWeight.length?`
        <div style="font-size:13px;font-weight:800;margin:12px 0 8px;">Évolution du poids</div>
        <div style="height:120px;"><canvas id="report-weight-chart"></canvas></div>
      `:''}
    </div>

    <!-- LIFESTYLE -->
    <div class="seclbl">💜 Lifestyle — Discipline</div>
    <div class="card" style="margin-bottom:24px;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="scard"><div class="slbl">Habitudes du jour</div><div class="sval">${habDone}/${habTotal}<span class="sunit"> faites</span></div></div>
        <div class="scard"><div class="slbl">Score</div><div class="sval" style="color:${lsScore>=70?'var(--green)':lsScore>=40?'var(--gold)':'var(--red)'};">${lsScore}<span class="sunit">%</span></div></div>
        <div class="scard" style="grid-column:span 2;"><div class="slbl">Tâches programmées</div><div class="sval">${lsDone}/${lsAll}<span class="sunit"> terminées</span></div></div>
      </div>
      <div class="progwrap" style="margin-top:12px;"><div class="progbar" style="width:${lsScore}%;background:${lsScore>=70?'var(--green)':lsScore>=40?'var(--gold)':'var(--red)'};"></div></div>
    </div>
  `;

  // Draw PNL chart in report
  setTimeout(()=>{
    const pnlCanvas=document.getElementById('report-pnl-chart');
    if(pnlCanvas){
      const sorted=[...trades].filter(t=>t.result).sort((a,b)=>new Date(a.date)-new Date(b.date));
      let cum=0,data=[0];
      sorted.forEach(t=>{cum+=t.pnl;data.push(parseFloat(cum.toFixed(2)));});
      const isPos=cum>=0,color=isPos?'#2eb872':'#e05252';
      if(reportPnlChart){reportPnlChart.destroy();reportPnlChart=null;}
      reportPnlChart=new Chart(pnlCanvas,{type:'line',data:{labels:data.map((_,i)=>i),datasets:[{data,borderColor:color,backgroundColor:isPos?'rgba(46,184,114,.07)':'rgba(224,82,82,.07)',fill:true,tension:.4,pointRadius:2,borderWidth:2}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{display:false},y:{ticks:{font:{size:9},color:'#666',callback:v=>(v>=0?'+':'')+v+'$'},grid:{color:'rgba(128,128,128,.07)'}}}}});
    }
    const wCanvas=document.getElementById('report-weight-chart');
    if(wCanvas&&bodyWeight.length){
      if(reportWeightChart){reportWeightChart.destroy();reportWeightChart=null;}
      reportWeightChart=new Chart(wCanvas,{type:'line',data:{labels:bodyWeight.map(w=>{const d=new Date(w.date+'T12:00:00');return d.getDate()+'/'+(d.getMonth()+1);}),datasets:[{data:bodyWeight.map(w=>w.kg),borderColor:'#aaa',backgroundColor:'rgba(170,170,170,.07)',fill:true,tension:.4,pointRadius:3,borderWidth:2}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{ticks:{font:{size:9},color:'#666'},grid:{display:false}},y:{ticks:{font:{size:9},color:'#666',callback:v=>v+'kg'},grid:{color:'rgba(128,128,128,.07)'}}}}});
    }
  },100);
}


const LS_KEY = 'dashboard_v1';
function saveAll(){
  try{
    localStorage.setItem(LS_KEY, JSON.stringify({
      trades, habits, sessions, weekPlan, sessionHistory,
      swimSessions, budgetCats, tasks, lsTasks, bodyWeight
    }));
  } catch(e){ console.warn('save failed',e); }
}
function loadAll(){
  try{
    const raw = localStorage.getItem(LS_KEY);
    if(!raw) return false;
    const d = JSON.parse(raw);
    if(d.trades)         trades         = d.trades;
    if(d.habits)         habits         = d.habits;
    if(d.sessions)       sessions       = d.sessions;
    if(d.weekPlan)       weekPlan       = d.weekPlan;
    if(d.sessionHistory) sessionHistory = d.sessionHistory;
    if(d.swimSessions)   swimSessions   = d.swimSessions;
    if(d.budgetCats)     budgetCats     = d.budgetCats;
    if(d.tasks)          tasks          = d.tasks;
    if(d.lsTasks)        lsTasks        = d.lsTasks;
    if(d.bodyWeight)     bodyWeight     = d.bodyWeight;
    return true;
  } catch(e){ return false; }
}

// ====== CLOCK & DATE ======
function updateClock(){
  const now=new Date();
  const t=now.toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
  document.getElementById('clock').textContent=t;
  document.getElementById('clock2').textContent=t;
}
setInterval(updateClock,1000); updateClock();

// ====== TOAST ======
function toast(msg){
  const el=document.getElementById('toast');
  el.textContent=msg; el.classList.add('show');
  setTimeout(()=>el.classList.remove('show'),2300);
}

// ====== INIT ======
window.onload=()=>{
  const now=new Date();
  const ds=['Dimanche','Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi'];
  const ms=['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];
  document.getElementById('hday').textContent=ds[now.getDay()];
  document.getElementById('hdate').textContent=now.getDate()+' '+ms[now.getMonth()]+' '+now.getFullYear();

  // Load saved data
  const loaded = loadAll();
  if(loaded) toast('✓ Données restaurées');

  resetTradeForm();
  document.getElementById('lst-date').value=now.toISOString().split('T')[0];
  renderTrades(); renderHabits(); renderLsScheduled(); renderMuscu();
  renderSwimStats(); renderWeightChart(); renderBudget(); renderTasks(); renderHome();

  // Register Service Worker
  if('serviceWorker' in navigator){
    navigator.serviceWorker.register('./sw.js').catch(()=>{});
  }
};
</script>
</body>
</html>
