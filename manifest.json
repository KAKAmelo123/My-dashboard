<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,viewport-fit=cover">
<title>Mon Dashboard</title>

<!-- PWA -->
<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#0f0f14" id="theme-color-meta">
<meta name="mobile-web-app-capable" content="yes">

<!-- iOS Safari PWA -->
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Dashboard">
<link rel="apple-touch-icon" href="apple-touch-icon.png">

<!-- Splash screens iOS (optionnel) -->
<meta name="format-detection" content="telephone=no">

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0f0f14;--card:#1a1a24;--card2:#22222e;--border:#2c2c3c;
  --text:#f0f0f8;--muted:#686880;--radius:16px;--rsm:10px;
  --accent:#1a8cff;--green:#2eb872;--red:#e05252;--gold:#f5a623;--purple:#c084fc;
  --safe-top: env(safe-area-inset-top, 0px);
  --safe-bottom: env(safe-area-inset-bottom, 0px);
}
[data-theme="light"]{
  --bg:#f2f2f7;--card:#ffffff;--card2:#f7f7fb;--border:#e2e2ec;
  --text:#0f0f14;--muted:#9999aa;
}
html,body{height:100%;background:var(--bg);font-family:-apple-system,BlinkMacSystemFont,'SF Pro Display',sans-serif;color:var(--text);}
.app{max-width:430px;margin:0 auto;min-height:100vh;padding-bottom:calc(86px + var(--safe-bottom));padding-top:var(--safe-top);position:relative;}
.statusbar{display:flex;justify-content:space-between;align-items:center;padding:12px 20px 4px;font-size:12px;font-weight:600;color:var(--muted);}
.tabbar{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:430px;max-width:100vw;background:var(--card);border-top:.5px solid var(--border);display:flex;padding:8px 0;padding-bottom:calc(8px + var(--safe-bottom));z-index:100;}
.fab{position:fixed;bottom:calc(94px + var(--safe-bottom));right:calc(50% - 215px + 16px);width:54px;height:54px;border-radius:50%;background:var(--accent);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 6px 24px rgba(26,140,255,.4);z-index:99;transition:transform .15s;}
.fab:active{transform:scale(.9);}
.fab i{font-size:26px;color:#fff;}

/* ── Section tints ── */
.tint-swim   { background: linear-gradient(180deg,rgba(14,90,160,.35) 0%,transparent 280px); }
.tint-muscu  { background: linear-gradient(180deg,rgba(60,60,60,.5)  0%,transparent 280px); }
.tint-trade-pos { background: linear-gradient(180deg,rgba(10,50,20,.55) 0%,transparent 280px); }
.tint-trade-neg { background: linear-gradient(180deg,rgba(50,10,10,.55) 0%,transparent 280px); }
.tint-lifestyle { background: linear-gradient(180deg,rgba(100,30,160,.3) 0%,transparent 280px); }
.tint-cours  { background: linear-gradient(180deg,rgba(240,240,255,.06) 0%,transparent 280px); }
[data-theme="light"] .tint-swim    { background: linear-gradient(180deg,rgba(14,90,180,.10) 0%,transparent 280px); }
[data-theme="light"] .tint-muscu   { background: linear-gradient(180deg,rgba(100,100,110,.10) 0%,transparent 280px); }
[data-theme="light"] .tint-trade-pos { background: linear-gradient(180deg,rgba(10,100,40,.08) 0%,transparent 280px); }
[data-theme="light"] .tint-trade-neg { background: linear-gradient(180deg,rgba(160,20,20,.07) 0%,transparent 280px); }
[data-theme="light"] .tint-lifestyle { background: linear-gradient(180deg,rgba(140,40,220,.07) 0%,transparent 280px); }
[data-theme="light"] .tint-cours   { background: linear-gradient(180deg,rgba(0,0,40,.04) 0%,transparent 280px); }

/* ── Status & Header ── */
.statusbar{display:flex;justify-content:space-between;align-items:center;padding:12px 20px 4px;font-size:12px;font-weight:600;color:var(--muted);}
.header{padding:6px 20px 14px;display:flex;align-items:center;gap:10px;}
.header h1{font-size:26px;font-weight:800;color:var(--text);flex:1;}
.icon-btn{width:38px;height:38px;border-radius:50%;background:var(--card2);border:.5px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--muted);font-size:18px;flex-shrink:0;transition:opacity .15s;}
.icon-btn:active{opacity:.6;}
.avatar{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#1a8cff,#00d4aa);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:#fff;flex-shrink:0;}

/* ── Content & Pages ── */
.content{padding:0 16px 16px;}
.page{display:none;animation:fu .22s ease;}
.page.active{display:block;}
@keyframes fu{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

/* ── Tab bar ── */
.tabbar{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:430px;max-width:100vw;background:var(--card);border-top:.5px solid var(--border);display:flex;padding:8px 0 20px;z-index:100;}
.tabitem{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer;color:var(--muted);font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;transition:color .15s;}
.tabitem.active{color:var(--accent);}
.tabitem i{font-size:21px;}

/* ── Sub-tabs ── */
.subtabs{display:flex;gap:8px;margin-bottom:16px;overflow-x:auto;padding-bottom:2px;scrollbar-width:none;}
.subtabs::-webkit-scrollbar{display:none;}
.stab{padding:8px 18px;border-radius:20px;font-size:13px;font-weight:700;border:1px solid var(--border);background:var(--card2);color:var(--muted);cursor:pointer;white-space:nowrap;flex-shrink:0;transition:all .15s;}
.stab.active{background:var(--accent);color:#fff;border-color:var(--accent);}
.subpage{display:none;}.subpage.active{display:block;}

/* ── Generic cards ── */
.card{background:var(--card);border:.5px solid var(--border);border-radius:var(--radius);padding:16px;margin-bottom:12px;}
.card2{background:var(--card2);border-radius:var(--rsm);padding:12px;}
.seclbl{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin:18px 0 10px;}

/* ── Stats grid ── */
.sgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:14px;}
.scard{background:var(--card2);border-radius:var(--rsm);padding:14px;}
.slbl{font-size:11px;color:var(--muted);margin-bottom:4px;}
.sval{font-size:22px;font-weight:800;color:var(--text);}
.sunit{font-size:12px;font-weight:400;color:var(--muted);}

/* ── FAB ── */
.fab{position:fixed;bottom:94px;right:calc(50% - 215px + 16px);width:54px;height:54px;border-radius:50%;background:var(--accent);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 6px 24px rgba(26,140,255,.4);z-index:99;transition:transform .15s;}
.fab:active{transform:scale(.9);}
.fab i{font-size:26px;color:#fff;}

/* ── Modals ── */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:200;display:none;align-items:flex-end;justify-content:center;backdrop-filter:blur(6px);}
.overlay.open{display:flex;}
.modal{width:100%;max-width:430px;background:var(--card);border-radius:24px 24px 0 0;padding:20px 20px 44px;max-height:92vh;overflow-y:auto;}
.mhandle{width:40px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 18px;}
.modal h2{font-size:20px;font-weight:800;margin-bottom:18px;}
.fg{margin-bottom:12px;}
.fg label{display:block;font-size:11px;font-weight:700;color:var(--muted);margin-bottom:6px;text-transform:uppercase;letter-spacing:.07em;}
.fg input,.fg select,.fg textarea{width:100%;padding:12px 14px;border-radius:var(--rsm);border:1px solid var(--border);background:var(--card2);color:var(--text);font-size:15px;font-family:inherit;outline:none;transition:border-color .15s;}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--accent);}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.frow3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;}
.calcbox{background:var(--card2);border-radius:var(--rsm);padding:14px;margin-bottom:12px;display:flex;justify-content:space-around;}
.citem{text-align:center;}
.cval{font-size:20px;font-weight:800;color:var(--text);}
.clbl{font-size:11px;color:var(--muted);}
.disc-big{font-size:30px;font-weight:900;color:var(--accent);text-align:center;margin:4px 0;}
.rng{width:100%;margin:4px 0 12px;accent-color:var(--accent);}
.btn{width:100%;padding:14px;border-radius:var(--radius);font-size:15px;font-weight:800;border:none;cursor:pointer;transition:opacity .15s;display:block;}
.btn:active{opacity:.8;}
.btnp{background:var(--accent);color:#fff;}
.btng{background:transparent;color:var(--muted);border:1px solid var(--border);margin-top:8px;}

/* ── Colors ── */
.pos{color:var(--green);}.neg{color:var(--red);}
.td-buy{background:rgba(46,184,114,.12);color:var(--green);}
.td-sell{background:rgba(224,82,82,.12);color:var(--red);}
.swim-c{color:#38bdf8;}
.swim-card{background:rgba(14,90,160,.15);border:.5px solid rgba(56,189,248,.18);}
[data-theme="light"] .swim-card{background:rgba(14,90,180,.07);}

/* ── Home quick cards ── */
.hgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:14px;}
.hcard{background:var(--card);border:.5px solid var(--border);border-radius:var(--radius);padding:14px;cursor:pointer;transition:transform .15s,opacity .15s;}
.hcard:active{transform:scale(.96);opacity:.85;}
.hcico{width:40px;height:40px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:10px;}
.hclbl{font-size:11px;color:var(--muted);margin-bottom:2px;}
.hcval{font-size:22px;font-weight:900;color:var(--text);}

/* ── Week grid ── */
.wgrid{display:grid;grid-template-columns:repeat(7,1fr);gap:5px;margin-bottom:14px;}
.wday{background:var(--card);border:.5px solid var(--border);border-radius:var(--rsm);padding:8px 3px;text-align:center;cursor:pointer;transition:all .15s;}
.wday.active{background:var(--accent);border-color:var(--accent);}
.wday.has{border-color:#666;}
.wdname{font-size:9px;color:var(--muted);font-weight:700;text-transform:uppercase;}
.wday.active .wdname,.wday.active .wdsess{color:#fff;}
.wdsess{font-size:9px;font-weight:700;color:var(--text);margin-top:3px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;}
.wdot{width:5px;height:5px;border-radius:50%;background:var(--green);margin:3px auto 0;}

/* ── Exercise blocks ── */
.exblock{background:var(--card);border:.5px solid var(--border);border-radius:var(--radius);padding:14px;margin-bottom:10px;}
.exhead{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;}
.exname{font-size:14px;font-weight:800;color:var(--text);}
.exgrp{font-size:11px;color:var(--muted);background:var(--card2);padding:2px 8px;border-radius:8px;}
.setscol{display:flex;flex-direction:column;gap:6px;}
.setrow{display:grid;grid-template-columns:26px 1fr 1fr 26px;gap:8px;align-items:center;}
.setbadge{width:22px;height:22px;border-radius:50%;background:var(--card2);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--muted);}
.setin{padding:8px;border-radius:8px;border:1px solid var(--border);background:var(--card2);color:var(--text);font-size:14px;font-weight:700;text-align:center;width:100%;outline:none;}
.setin:focus{border-color:var(--accent);}
.setdel{background:transparent;border:none;color:var(--muted);cursor:pointer;padding:0;display:flex;align-items:center;justify-content:center;}
.addsetbtn{width:100%;padding:8px;border-radius:8px;border:1px dashed var(--border);background:transparent;color:var(--accent);font-size:13px;font-weight:700;cursor:pointer;margin-top:6px;}

/* ── Session template cards ── */
.sesscard{background:var(--card);border:.5px solid var(--border);border-radius:var(--radius);padding:14px;margin-bottom:8px;cursor:pointer;transition:opacity .15s;}
.sesscard:active{opacity:.7;}
.sesshead{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.sessname{font-size:15px;font-weight:800;color:var(--text);}
.sesscount{font-size:11px;color:var(--muted);background:var(--card2);padding:2px 8px;border-radius:8px;}
.exchips{display:flex;flex-wrap:wrap;gap:5px;}
.exchip{font-size:11px;color:var(--muted);background:var(--card2);padding:2px 8px;border-radius:8px;}

/* ── PNL hero ── */
.pnlhero{background:var(--card);border:.5px solid var(--border);border-radius:var(--radius);padding:20px;margin-bottom:14px;}
.pnllbl{font-size:12px;color:var(--muted);margin-bottom:4px;}
.pnlbig{font-size:38px;font-weight:900;}
.pnlstats{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:14px;}
.pnls{text-align:center;}
.pnlsv{font-size:16px;font-weight:800;color:var(--text);}
.pnlsl{font-size:10px;color:var(--muted);}
.chartwrap{position:relative;height:140px;}

/* ── Trade rows ── */
.traderow{background:var(--card);border:.5px solid var(--border);border-radius:var(--rsm);padding:12px 14px;margin-bottom:8px;display:flex;align-items:center;gap:12px;}
.tradedir{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.trinfo{flex:1;min-width:0;}
.trpair{font-size:14px;font-weight:800;color:var(--text);}
.trmeta{font-size:11px;color:var(--muted);}
.trright{text-align:right;flex-shrink:0;}
.trpips{font-size:15px;font-weight:800;}

/* ── Budget ── */
.bcat{margin-bottom:14px;}
.bcath{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;}
.bcatn{font-size:13px;font-weight:700;color:var(--text);}
.bcatamt{font-size:12px;color:var(--muted);}
.bbarw{height:6px;background:var(--card2);border-radius:3px;overflow:hidden;}
.bbar{height:100%;border-radius:3px;transition:width .5s;}
.bok{background:var(--accent);}.bwarn{background:var(--gold);}.bover{background:var(--red);}
.bcatdel{background:transparent;border:none;color:var(--muted);cursor:pointer;font-size:14px;padding:2px 6px;}

/* ── Habits ── */
.hrow{background:var(--card);border:.5px solid var(--border);border-radius:var(--rsm);padding:12px 14px;margin-bottom:8px;display:flex;align-items:center;gap:12px;}
.hemi{font-size:22px;flex-shrink:0;}
.hname{flex:1;font-size:14px;font-weight:700;color:var(--text);}
.hbtn{width:36px;height:36px;border-radius:50%;border:1.5px solid var(--border);background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px;transition:all .15s;}
.hbtn.y{background:rgba(46,184,114,.15);border-color:var(--green);color:var(--green);}
.hbtn.n{background:rgba(224,82,82,.15);border-color:var(--red);color:var(--red);}
.hdel{background:transparent;border:none;color:var(--muted);cursor:pointer;font-size:14px;display:flex;align-items:center;}

/* ── Tasks ── */
.taskrow{display:flex;align-items:center;gap:10px;padding:8px 0;border-top:.5px solid var(--border);cursor:pointer;}
.tchk{width:20px;height:20px;border-radius:50%;border:1.5px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .15s;}
.tchk.done{background:var(--green);border-color:var(--green);}
.ttxt{flex:1;font-size:13px;color:var(--text);}
.ttxt.done{text-decoration:line-through;color:var(--muted);}
.ttag{font-size:10px;padding:2px 7px;border-radius:8px;font-weight:700;}

/* ── Prog bar ── */
.progwrap{height:8px;background:var(--card2);border-radius:4px;overflow:hidden;margin-top:8px;}
.progbar{height:100%;border-radius:4px;background:var(--green);transition:width .4s;}

/* ── Settings ── */
.srow{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:.5px solid var(--border);}
.srow:last-child{border-bottom:none;}
.stitle{font-size:14px;font-weight:700;color:var(--text);}
.ssub{font-size:11px;color:var(--muted);}
.toggle{width:46px;height:26px;border-radius:13px;background:var(--card2);border:1px solid var(--border);cursor:pointer;position:relative;transition:background .2s;}
.toggle.on{background:var(--accent);}
.tknob{width:20px;height:20px;border-radius:50%;background:#fff;position:absolute;top:2px;left:2px;transition:left .2s;box-shadow:0 1px 4px rgba(0,0,0,.4);}
.toggle.on .tknob{left:22px;}
.emiinput{width:54px;padding:6px;border-radius:8px;border:1px solid var(--border);background:var(--card2);color:var(--text);font-size:20px;text-align:center;outline:none;}

/* ── Muscu home prog ── */
.mhprow{display:flex;align-items:center;gap:8px;margin-bottom:12px;}
.mhpname{font-size:13px;font-weight:700;color:var(--text);min-width:0;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.mhpdiff{font-size:13px;font-weight:800;flex-shrink:0;}
.mhpbar{flex:1;height:4px;background:var(--card2);border-radius:2px;overflow:hidden;max-width:80px;}
.mhpfill{height:100%;border-radius:2px;}

/* ── Empty ── */
.empty{text-align:center;padding:32px 20px;color:var(--muted);font-size:14px;}
.empty i{font-size:38px;display:block;margin-bottom:8px;opacity:.35;}

/* ── Toast ── */
.toast{position:fixed;top:56px;left:50%;transform:translateX(-50%) translateY(-10px);background:var(--text);color:var(--bg);padding:10px 22px;border-radius:20px;font-size:13px;font-weight:700;z-index:600;opacity:0;transition:all .25s;pointer-events:none;white-space:nowrap;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
</style>
</head>
<body>
<div class="app" id="app">

<!-- ==================== HOME ==================== -->
<div id="page-home" class="page active">
  <div class="statusbar"><span id="clock">9:41</span><div style="display:flex;gap:5px;"><i class="ti ti-wifi" style="font-size:13px;"></i><i class="ti ti-battery" style="font-size:13px;"></i></div></div>
  <div class="header">
    <div class="icon-btn" onclick="goTab('settings')"><i class="ti ti-settings"></i></div>
    <h1>Dashboard</h1>
    <div class="icon-btn" onclick="goTab('report')" style="color:var(--gold);border-color:rgba(245,166,35,.3);" title="Compte rendu"><i class="ti ti-chart-bar"></i></div>
  </div>
  <div class="content">
    <div class="card" style="margin-bottom:14px;">
      <div style="font-size:12px;color:var(--muted);" id="hday"></div>
      <div style="font-size:20px;font-weight:800;margin-bottom:10px;" id="hdate"></div>
      <span style="background:rgba(245,166,35,.15);color:var(--gold);padding:4px 12px;border-radius:20px;font-size:12px;font-weight:800;">🔥 7 jours de série</span>
    </div>
    <div class="seclbl">Vue rapide</div>
    <div class="hgrid">
      <div class="hcard" onclick="goTab('sport')">
        <div class="hcico" style="background:rgba(60,60,60,.4);"><span id="emo-sport">🏋️</span></div>
        <div class="hclbl">Muscu aujourd'hui</div>
        <div class="hcval" id="hc-muscu">—</div>
      </div>
      <div class="hcard" onclick="goTab('finance')">
        <div class="hcico" style="background:rgba(46,184,114,.12);"><span id="emo-trading">📈</span></div>
        <div class="hclbl">PNL du mois</div>
        <div class="hcval pos" id="hc-pnl">+0 $</div>
      </div>
      <div class="hcard" onclick="goTab('lifestyle')">
        <div class="hcico" style="background:rgba(192,132,252,.12);"><span id="emo-lifestyle">💜</span></div>
        <div class="hclbl">Habitudes du jour</div>
        <div class="hcval" id="hc-habits">0/0</div>
      </div>
      <div class="hcard" onclick="goTab('cours')">
        <div class="hcico" style="background:rgba(240,240,255,.07);"><span id="emo-cours">📚</span></div>
        <div class="hclbl">Cours</div>
        <div class="hcval" id="hc-cours">0 tâche</div>
      </div>
    </div>
    <div class="seclbl">Progression musculation</div>
    <div class="card" id="home-muscu-prog"><div class="empty"><i class="ti ti-barbell"></i>Lance ta première séance</div></div>
    <div class="seclbl">Derniers trades</div>
    <div id="home-trades"><div class="empty" style="padding:16px 0;"><i class="ti ti-chart-candle"></i>Aucun trade</div></div>
  </div>
</div>

<!-- ==================== SPORT ==================== -->
<div id="page-sport" class="page">
  <div class="statusbar"><span id="clock2">9:41</span></div>
  <div class="header">
    <h1>Sport</h1>
    <div class="icon-btn" style="color:#38bdf8;border-color:rgba(56,189,248,.25);"><i class="ti ti-swimming"></i></div>
  </div>
